{
  "name": "telegram-opencode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node telegram-notifier.mjs",
    "stop": "node manage-notifier.mjs stop",
    "status": "node manage-notifier.mjs status",
    "check": "node --check telegram-notifier.mjs && node --check manage-notifier.mjs && tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "tray:windows": "powershell -ExecutionPolicy Bypass -File .\\tray-telegram-notifier.ps1"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
